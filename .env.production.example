# 生产环境配置示例
# 复制此文件为 .env.production 并填入实际值

# 应用配置
DEBUG=false

# D1 数据库配置
D1_DATABASE_ID=503a4b2f-b062-4ec5-be21-edfd0e7d8a2d
D1_DATABASE_NAME=ai-briefing-assistant-prod
D1_ACCOUNT_ID=your-account-id
D1_API_TOKEN=your-api-token
D1_USE_CLOUD_AS_SOURCE=true

# 安全配置
SECRET_KEY=your-secret-key-here

# CORS 配置（JSON 数组格式或逗号分隔）
CORS_ORIGINS=["https://your-frontend-domain.vercel.app","https://your-frontend-domain.pages.dev"]

# AI 配置
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# 可选：其他 AI 提供商
# OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key
# GEMINI_API_KEY=your-gemini-api-key
# ZHIPU_API_KEY=your-zhipu-api-key
# QWEN_API_KEY=your-qwen-api-key

# AI 参数
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.7
AI_TIMEOUT=30
